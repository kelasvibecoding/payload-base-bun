{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PayloadBase",
  "version": "0.1.13",
  "identifier": "com.kelasvibecoding.payloadbase",
  "build": {
    "frontendDist": "./dist",
    "devUrl": "http://localhost:3300",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bun run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Payload Base",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "showMenuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": [
          "English"
        ]
      }
    },
    "resources": {
      "../.next/standalone/": "server/"
    }
  }
}
