# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
/.next/
/.next-dev/
/out/
/build

# PWA (Automatically generated build artifacts)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# Payload CMS
/media

# Tauri Bundled Runtime Sidecars
# (downloaded via: bun run setup:runtimes)
/src-tauri/bin/*.exe
/src-tauri/bin/*.zip

# Environment
.env
.env*.local

# Database
local.db
local.db-journal
*.db

# Testing (Playwright & Vitest)
/coverage
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/

# Typescript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# Misc & Debug
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-error.log

# IDE & Editor
/.idea/*
!/.idea/runConfigurations
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Setup Temporary Files
.temp-payload-base-*/
.agent

# PWA
+ public/sw.js
+ public/sw.js.map
+ public/workbox-*.js
+ public/workbox-*.js.map
